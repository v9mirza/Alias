# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
# Local MongoDB without auth:
MONGODB_URI=mongodb://127.0.0.1:27017/alias
# MongoDB with auth (example):
# MONGODB_URI=mongodb://admin:pass@127.0.0.1:27017/alias?authSource=admin

# JWT Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS Settings
# Frontend dev server runs on port 5173 (Vite default)
CORS_ORIGIN=http://localhost:5173
# Allow all origins in development (optional):
# CORS_ORIGIN=*

# Rate Limiter
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
